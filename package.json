{
  "name": "cacheiro",
  "version": "0.5.0-beta.11",
  "description": "The simplest -yet effective- cache manager",
  "author": "Donato Lorenzo <donato@afialapis.com>",
  "contributors": [
    "Donato Lorenzo <donato@afialapis.com>"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/afialapis/cacheiro.git"
  },
  "bugs": {
    "url": "https://github.com/afialapis/cacheiro/issues"
  },
  "homepage": "https://www.afialapis.com/os/cacheiro",
  "type": "module",
  "exports": {
    ".": "./src/index.mjs"
  },
  "files": [
    "src",
    "package.json",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "reset": "rm -fr arredemo node_modules package-lock.json && npm i",
    "lint": "biome check ./src ./test --reporter=github",
    "lint:fix": "biome check --write ./src ./test --reporter=github",
    "test": "node --test ./test/index.mjs",
    "site": "npx arredemo build",
    "prepublishOnly": "npm run lint && npm run test && npm run site"
  },
  "dependencies": {
    "redis": "^5.11.0",
    "tinguir": "^0.0.7"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.5"
  },
  "engines": {
    "node": ">=24"
  }
}
